---
interface Props {
  pdfType: string;
  label: string;
  sublabel?: string;
  accent?: string;
}

const { pdfType, label, sublabel, accent = "brand" } = Astro.props;

const accentMap: Record<string, { bg: string; hover: string; text: string; glow: string }> = {
  brand:  { bg: "bg-brand-500/10", hover: "hover:bg-brand-500/20", text: "text-brand-400", glow: "group-hover:shadow-brand-500/10" },
  blue:   { bg: "bg-blue-500/10", hover: "hover:bg-blue-500/20", text: "text-blue-400", glow: "group-hover:shadow-blue-500/10" },
  rose:   { bg: "bg-rose-500/10", hover: "hover:bg-rose-500/20", text: "text-rose-400", glow: "group-hover:shadow-rose-500/10" },
  red:    { bg: "bg-red-500/10", hover: "hover:bg-red-500/20", text: "text-red-400", glow: "group-hover:shadow-red-500/10" },
  amber:  { bg: "bg-amber-500/10", hover: "hover:bg-amber-500/20", text: "text-amber-400", glow: "group-hover:shadow-amber-500/10" },
  violet: { bg: "bg-violet-500/10", hover: "hover:bg-violet-500/20", text: "text-violet-400", glow: "group-hover:shadow-violet-500/10" },
  cyan:   { bg: "bg-cyan-500/10", hover: "hover:bg-cyan-500/20", text: "text-cyan-400", glow: "group-hover:shadow-cyan-500/10" },
  pink:   { bg: "bg-pink-500/10", hover: "hover:bg-pink-500/20", text: "text-pink-400", glow: "group-hover:shadow-pink-500/10" },
  orange: { bg: "bg-orange-500/10", hover: "hover:bg-orange-500/20", text: "text-orange-400", glow: "group-hover:shadow-orange-500/10" },
};

const c = accentMap[accent] || accentMap.brand;
---

<button
  data-pdf={pdfType}
  class:list={[
    "pdf-dl group relative flex sm:inline-flex items-center gap-2.5 px-4 py-2.5 rounded-xl cursor-pointer w-full sm:w-auto",
    "bg-surface-100 border border-surface-300/60",
    "hover:border-surface-400 hover:bg-surface-200/80",
    "active:scale-[0.98] transition-all duration-200",
    "group-hover:shadow-lg", c.glow,
  ]}
>
  <!-- Icon -->
  <div class:list={["flex-shrink-0 w-8 h-8 rounded-lg flex items-center justify-center transition-colors", c.bg, c.hover]}>
    <svg class:list={["w-3.5 h-3.5", c.text]} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12M12 16.5V3"/>
    </svg>
  </div>

  <!-- Text -->
  <div class="text-left min-w-0">
    <span class="pdf-label block text-xs font-semibold text-surface-900 group-hover:text-surface-950 transition-colors leading-tight">{label}</span>
    {sublabel && <span class="block text-2xs text-surface-600 mt-0.5">{sublabel}</span>}
  </div>

  <!-- Arrow -->
  <svg class:list={["w-3 h-3 ml-auto flex-shrink-0 opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-200", c.text]} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"/>
  </svg>

  <!-- Pulse ring on hover -->
  <div class="absolute inset-0 rounded-xl ring-1 ring-inset ring-white/[0.03] pointer-events-none"></div>
</button>
