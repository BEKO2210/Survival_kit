  <!-- PDF Data -->
  <script is:inline define:vars={{
    pdfShoppingLists: shoppingLists,
    pdfWaterNeeds: waterNeeds,
    pdfWaterStorage: waterStorage,
    pdfWaterPurification: waterPurification,
    pdfFirstAidItems: firstAidKit.items,
    pdfEmergencyPlan: emergencyPlan,
    pdfDocuments: importantDocuments,
    pdfHygieneItems: hygieneItems,
    pdfToolsAndEquipment: toolsAndEquipment,
    pdfChildrenSpecial: childrenSpecial,
    pdfFoodItems: foodItems,
  }}>
    window.__pdfData = {
      shoppingLists: pdfShoppingLists,
      waterNeeds: pdfWaterNeeds,
      waterStorage: pdfWaterStorage,
      waterPurification: pdfWaterPurification,
      firstAidItems: pdfFirstAidItems,
      emergencyPlan: pdfEmergencyPlan,
      documents: pdfDocuments,
      hygieneItems: pdfHygieneItems,
      toolsAndEquipment: pdfToolsAndEquipment,
      childrenSpecial: pdfChildrenSpecial,
      foodItems: pdfFoodItems,
    };
  </script>

  <script>
    let pdfModule: any = null;
    let JSZipModule: any = null;

    async function loadPdfDeps() {
      if (!pdfModule) {
        const [pdf, zip] = await Promise.all([
          import('../lib/pdfGenerator'),
          import('jszip'),
        ]);
        pdfModule = pdf;
        JSZipModule = zip.default;
      }
    }

    const data = (window as any).__pdfData;

    function getPdf(type: string) {
      const m = pdfModule;
      switch (type) {
        case 'shop-0': return { doc: m.generateShoppingListPdf(data.shoppingLists[0]), name: 'einkaufsliste-1-person.pdf' };
        case 'shop-1': return { doc: m.generateShoppingListPdf(data.shoppingLists[1]), name: 'einkaufsliste-2-personen.pdf' };
        case 'shop-2': return { doc: m.generateShoppingListPdf(data.shoppingLists[2]), name: 'einkaufsliste-familie.pdf' };
        case 'water': return { doc: m.generateWaterPdf(data.waterNeeds, data.waterStorage, data.waterPurification), name: 'wasser-uebersicht.pdf' };
        case 'firstaid': return { doc: m.generateFirstAidPdf(data.firstAidItems), name: 'erste-hilfe-checkliste.pdf' };
        case 'emergency': return { doc: m.generateEmergencyPlanPdf(data.emergencyPlan), name: 'notfallplan-10-schritte.pdf' };
        case 'documents': return { doc: m.generateDocumentsPdf(data.documents), name: 'dokumente-checkliste.pdf' };
        case 'hygiene': return { doc: m.generateHygienePdf(data.hygieneItems), name: 'hygiene-checkliste.pdf' };
        case 'equipment': return { doc: m.generateEquipmentPdf(data.toolsAndEquipment), name: 'ausruestung-werkzeuge.pdf' };
        case 'children': return { doc: m.generateChildrenPdf(data.childrenSpecial), name: 'kinder-im-notfall.pdf' };
        case 'food': return { doc: m.generateFoodPdf(data.foodItems), name: 'nahrungsmittel-tabelle.pdf' };
        default: return null;
      }
    }

    const allTypes = ['shop-0','shop-1','shop-2','water','food','firstaid','emergency','documents','hygiene','equipment','children'];

    async function animateDownload(btn: Element, type: string) {
      const label = btn.querySelector('.pdf-label');
      const origText = label?.textContent || '';
      const el = btn as HTMLElement;

      let bar = el.querySelector('.dl-progress') as HTMLElement;
      if (!bar) {
        bar = document.createElement('div');
        bar.className = 'dl-progress';
        el.appendChild(bar);
      }

      el.classList.add('is-downloading');
      bar.style.width = '0%';
      if (label) label.textContent = 'Laden...';

      await loadPdfDeps();

      if (type === 'all') {
        const total = allTypes.length;
        if (label) label.textContent = `0 / ${total} PDFs ...`;

        const zip = new JSZipModule();
        for (let i = 0; i < allTypes.length; i++) {
          const result = getPdf(allTypes[i]);
          if (result) {
            const blob = result.doc.output('blob');
            zip.file(result.name, blob);
          }
          bar.style.width = `${((i + 1) / total) * 100}%`;
          if (label) label.textContent = `${i + 1} / ${total} PDFs ...`;
        }

        zip.generateAsync({ type: 'blob' }).then((content: Blob) => {
          const url = URL.createObjectURL(content);
          const a = document.createElement('a');
          a.href = url;
          a.download = 'be-prepared-survival-alle-pdfs.zip';
          a.click();
          URL.revokeObjectURL(url);

          setTimeout(() => {
            el.classList.remove('is-downloading');
            el.classList.add('is-done');
            if (label) label.textContent = 'ZIP heruntergeladen!';
            setTimeout(() => {
              el.classList.remove('is-done');
              if (label) label.textContent = origText;
              bar.style.width = '0%';
            }, 2000);
          }, 300);
        });
      } else {
        bar.style.width = '60%';
        setTimeout(() => {
          const result = getPdf(type);
          if (result) pdfModule.downloadPdf(result.doc, result.name);
          bar.style.width = '100%';
          setTimeout(() => {
            el.classList.remove('is-downloading');
            el.classList.add('is-done');
            if (label) label.textContent = 'Heruntergeladen!';
            setTimeout(() => {
              el.classList.remove('is-done');
              if (label) label.textContent = origText;
              bar.style.width = '0%';
            }, 1500);
          }, 300);
        }, 200);
      }
    }

    document.querySelectorAll('.pdf-dl').forEach((btn) => {
      btn.addEventListener('click', () => {
        if ((btn as HTMLElement).classList.contains('is-downloading')) return;
        animateDownload(btn, (btn as HTMLElement).dataset.pdf!);
      });
    });

    // === LOCALSTORAGE PERSISTENCE ===
    const calcInputIds = ['water-adults', 'water-kids', 'water-days', 'cal-persons', 'cal-daily', 'cal-days', 'blast-distance'];
    calcInputIds.forEach(id => {
      const el = document.getElementById(id) as HTMLInputElement;
      if (!el) return;
      const saved = localStorage.getItem('ww3-' + id);
      if (saved) el.value = saved;
      el.addEventListener('change', () => localStorage.setItem('ww3-' + id, el.value));
    });
    const blastSelect = document.getElementById('blast-weapon') as HTMLSelectElement;
    if (blastSelect) {
      const saved = localStorage.getItem('ww3-blast-weapon');
      if (saved) blastSelect.value = saved;
      blastSelect.addEventListener('change', () => localStorage.setItem('ww3-blast-weapon', blastSelect.value));
    }

    // === FOOD TABLE LAZY LOAD ===
    document.getElementById('food-show-all')?.addEventListener('click', () => {
      document.querySelectorAll('.food-hidden-row').forEach(r => r.classList.remove('hidden', 'food-hidden-row'));
      document.getElementById('food-show-all-wrap')?.remove();
    });

    // === WASSERRECHNER ===
    document.getElementById('water-calc-btn')?.addEventListener('click', () => {
      const adults = parseInt((document.getElementById('water-adults') as HTMLInputElement).value) || 0;
      const kids = parseInt((document.getElementById('water-kids') as HTMLInputElement).value) || 0;
      const days = parseInt((document.getElementById('water-days') as HTMLInputElement).value) || 1;
      const adultLiters = adults * 2.5 * days;
      const kidLiters = kids * 1.5 * days;
      const total = adultLiters + kidLiters;
      const bottles6 = Math.ceil(total / 6);
      const el = document.getElementById('water-result')!;
      el.classList.remove('hidden');
      el.innerHTML = `<strong class="text-blue-400 text-lg">${total} Liter</strong> Wasser benötigt.<br>
        <span class="text-surface-600">${adults} Erw. × 2,5L × ${days} Tage = ${adultLiters}L</span><br>
        <span class="text-surface-600">${kids} Kinder × 1,5L × ${days} Tage = ${kidLiters}L</span><br>
        <span class="text-surface-600 mt-1 block">≈ ${bottles6} Sixpacks (6×1,5L) oder ${Math.ceil(total / 10)} 10L-Kanister</span>`;
    });

    // === KALORIENRECHNER ===
    document.getElementById('cal-calc-btn')?.addEventListener('click', () => {
      const persons = parseInt((document.getElementById('cal-persons') as HTMLInputElement).value) || 1;
      const daily = parseInt((document.getElementById('cal-daily') as HTMLInputElement).value) || 2000;
      const days = parseInt((document.getElementById('cal-days') as HTMLInputElement).value) || 14;
      const totalKcal = persons * daily * days;
      const riceKg = (totalKcal / 3600).toFixed(1);
      const nrgPacks = Math.ceil(totalKcal / 2300);
      const el = document.getElementById('cal-result')!;
      el.classList.remove('hidden');
      el.innerHTML = `<strong class="text-amber-400 text-lg">${totalKcal.toLocaleString('de-DE')} kcal</strong> Gesamtbedarf.<br>
        <span class="text-surface-600">${persons} Personen × ${daily} kcal × ${days} Tage</span><br>
        <span class="text-surface-600 mt-1 block">Entspricht ca. <strong>${riceKg} kg Reis</strong> oder <strong>${nrgPacks} NRG-5 Packungen</strong></span>`;
    });

    // === BLAST-RECHNER ===
    document.getElementById('blast-calc-btn')?.addEventListener('click', () => {
      const yieldKt = parseFloat((document.getElementById('blast-weapon') as HTMLSelectElement).value);
      const distKm = parseFloat((document.getElementById('blast-distance') as HTMLInputElement).value) || 0;
      const distM = distKm * 1000;

      // Cube-root scaling from 1kt reference values
      const scale = Math.pow(yieldKt, 1/3);
      const fireball = 50 * scale;
      const totalDest = 200 * scale;
      const severe = 600 * scale;
      const moderate = 1200 * scale;
      const thermal = 1000 * scale;

      let status = '';
      let color = '';
      if (distM < fireball) {
        status = 'Im Feuerball. Keine Überlebenschance.';
        color = 'text-red-500';
      } else if (distM < totalDest) {
        status = 'Zone der Totalzerstörung. Überlebenschance nahezu null.';
        color = 'text-red-500';
      } else if (distM < severe) {
        status = 'Schwere Schäden. Gebäude stürzen ein. Überleben nur in tiefem Schutzraum möglich.';
        color = 'text-red-400';
      } else if (distM < moderate) {
        status = 'Mittlere Schäden. Fenster bersten, Verletzungsgefahr. Schutzraum dringend empfohlen.';
        color = 'text-amber-400';
      } else if (distM < thermal) {
        status = 'Thermische Strahlung möglich. Verbrennungen im Freien. Im Gebäude bleiben!';
        color = 'text-amber-400';
      } else {
        status = 'Außerhalb der unmittelbaren Gefahrenzone. ABER: Fallout kann noch gefährlich sein! Schutzraum aufsuchen.';
        color = 'text-brand-400';
      }

      const el = document.getElementById('blast-result')!;
      el.classList.remove('hidden');
      el.innerHTML = `<strong class="${color} text-lg">${status}</strong><br>
        <span class="text-surface-600 mt-2 block">Bei ${yieldKt >= 1000 ? (yieldKt/1000) + ' Mt' : yieldKt + ' kt'} in ${distKm} km Entfernung:</span>
        <span class="text-surface-600">Feuerball: ${(fireball/1000).toFixed(1)} km | Totalzerstörung: ${(totalDest/1000).toFixed(1)} km | Schwere Schäden: ${(severe/1000).toFixed(1)} km</span>`;
    });

    // === SPEICHER-RECHNER ===
    function updateStorage() {
      let total = 0;
      document.querySelectorAll('.storage-check').forEach((cb) => {
        if ((cb as HTMLInputElement).checked) {
          total += parseFloat((cb as HTMLElement).dataset.size || '0');
        }
      });
      document.getElementById('storage-total')!.textContent = total.toFixed(1);
      const advice = document.getElementById('storage-advice')!;
      if (total === 0) advice.textContent = 'Wähle Tools oben aus';
      else if (total < 5) advice.textContent = 'Passt auf jedes Smartphone';
      else if (total < 20) advice.textContent = 'Eine 32 GB SD-Karte reicht';
      else if (total < 50) advice.textContent = 'Eine 64 GB SD-Karte empfohlen';
      else advice.textContent = 'Eine 128 GB SD-Karte empfohlen';
    }
    document.querySelectorAll('.storage-check').forEach(cb => cb.addEventListener('change', updateStorage));
  </script>
</Layout>
