---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import SectionHeader from '../components/SectionHeader.astro';
import BentoCard from '../components/BentoCard.astro';
import PdfButton from '../components/PdfButton.astro';
import {
  waterNeeds, waterStorage, waterPurification,
  foodItems, shoppingLists, firstAidKit,
  toolsAndEquipment, hygieneItems, importantDocuments,
  childrenSpecial, emergencyPlan, survivalScenarios,
  nuclearBombs, conventionalBombs, shelterTypes, shelterMaterials, falloutRules,
  offlineApps,
} from '../data/survivalData';

const foodCategories = [...new Set(foodItems.map(f => f.category))];

function badgeClass(p: string) {
  return p === 'hoch' ? 'badge badge-high' : p === 'mittel' ? 'badge badge-mid' : 'badge badge-low';
}
---

<Layout title="Be PREPared Survival Guide -- Krisenvorsorge für dich und deine Familie">
  <Navigation />

  <!-- Search overlay -->
  <div id="search-overlay" class="fixed inset-0 z-[60] bg-surface-0/95 backdrop-blur-xl hidden">
    <div class="max-w-2xl mx-auto px-4 pt-20 sm:pt-28">
      <div class="flex items-center gap-3 mb-6">
        <input id="search-input" type="search" placeholder="Suche z.B. Reis, Erste Hilfe, Wasserfilter..." autocomplete="off"
          class="flex-1 bg-surface-200 border border-surface-300 rounded-xl px-4 py-3 text-sm text-surface-900 placeholder-surface-600 focus:outline-none focus:ring-2 focus:ring-brand-500" />
        <button id="search-close" type="button" class="p-2.5 rounded-lg bg-surface-200 hover:bg-surface-300 text-surface-700 transition-colors" aria-label="Suche schließen">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div id="search-results" class="space-y-2 max-h-[60vh] overflow-y-auto"></div>
    </div>
  </div>

  <main class="min-h-screen">
    <!-- ===== HERO ===== -->
    <section id="start" class="relative min-h-[100svh] flex items-center justify-center px-4 pt-16 overflow-hidden">
      <div class="absolute inset-0 bg-surface-0 hero-gradient">
        <div class="absolute top-1/3 left-1/4 w-[28rem] h-[28rem] bg-red-500/[0.04] rounded-full blur-[100px] animate-pulse-soft"></div>
        <div class="absolute bottom-1/3 right-1/4 w-[24rem] h-[24rem] bg-brand-600/[0.04] rounded-full blur-[100px] animate-pulse-soft" style="animation-delay: 1.5s;"></div>
      </div>
      <div class="absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(circle, #ef4444 1px, transparent 1px); background-size: 32px 32px;"></div>

      <div class="relative z-10 text-center max-w-3xl mx-auto">
        <div class="mb-6" data-animate>
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-red-500/10 border border-red-500/20 text-red-400 text-xs font-medium tracking-wide">
            <span class="w-1.5 h-1.5 rounded-full bg-red-400 animate-pulse-soft"></span>
            Krisenvorsorge & Überleben
          </span>
        </div>

        <h1 class="text-4xl sm:text-6xl lg:text-7xl font-bold tracking-tight mb-5" data-animate>
          Be <span class="text-red-400">PREP</span>ared
          <span class="text-surface-950 ml-2">Survival Guide</span>
        </h1>

        <p class="text-base sm:text-lg text-surface-600 max-w-xl mx-auto mb-10 leading-relaxed" data-animate>
          Ich hab das hier zusammengestellt, weil ich selbst Vater bin und wissen will,
          dass meine Familie vorbereitet ist. Alles recherchiert, alles als PDF zum Ausdrucken.
        </p>

        <!-- Stats -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 max-w-2xl mx-auto mb-10" data-animate>
          <div class="card text-center py-4">
            <div class="text-2xl font-bold text-brand-400">{foodItems.length}+</div>
            <div class="text-xs text-surface-600 mt-0.5">Lebensmittel</div>
          </div>
          <div class="card text-center py-4">
            <div class="text-2xl font-bold text-blue-400">14</div>
            <div class="text-xs text-surface-600 mt-0.5">Sektionen</div>
          </div>
          <div class="card text-center py-4">
            <div class="text-2xl font-bold text-amber-400">{firstAidKit.items.length}</div>
            <div class="text-xs text-surface-600 mt-0.5">Erste-Hilfe Artikel</div>
          </div>
          <div class="card text-center py-4">
            <div class="text-2xl font-bold text-rose-400">{emergencyPlan.length}</div>
            <div class="text-xs text-surface-600 mt-0.5">Notfall-Schritte</div>
          </div>
        </div>

        <!-- CTA -->
        <div class="flex flex-col sm:flex-row gap-3 justify-center" data-animate>
          <a href="#downloads" class="cta-glow px-6 py-3 bg-red-600 hover:bg-red-500 text-white rounded-xl font-semibold text-sm transition-all hover:shadow-lg hover:shadow-red-600/20 hover:scale-[1.02] active:scale-[0.98]">
            Alle PDFs herunterladen
          </a>
          <a href="#notfallplan" class="px-6 py-3 bg-surface-200 hover:bg-surface-300 border border-surface-300 text-surface-900 rounded-xl font-semibold text-sm transition-all">
            Notfallplan ansehen
          </a>
        </div>

        <div class="mt-14 text-surface-600" data-animate>
          <svg class="w-5 h-5 mx-auto animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
          </svg>
        </div>
      </div>
    </section>

    <!-- ===== WASSER ===== -->
    <section class="py-3 sm:py-4 px-4 sm:px-6 max-w-7xl mx-auto">
      <details class="section-card group">
        <SectionHeader id="wasser" title="Wasser" subtitle="Ohne Wasser hast du 3 Tage. Punkt." accent="blue" collapsible />

      <div class="section-content">
      <div class="mb-4 sm:flex sm:justify-end" data-animate>
        <PdfButton pdfType="water" label="Wasser PDF" sublabel="Bedarf & Aufbereitung" accent="blue" />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" data-animate>
        <div class="card lg:col-span-2">
          <div class="mb-4">
            <h3 class="text-sm font-semibold text-blue-400 tracking-wide uppercase">Täglicher Wasserbedarf</h3>
          </div>
          <div class="space-y-2">
            {waterNeeds.map((w) => (
              <div class="flex items-center justify-between p-3 rounded-lg bg-surface-200/50 hover:bg-surface-200 transition-colors" data-stagger>
                <div>
                  <span class="text-sm font-medium text-surface-900">{w.situation}</span>
                  <span class="text-xs text-surface-600 ml-2 hidden sm:inline">-- {w.notes}</span>
                </div>
                <span class="text-sm font-semibold text-blue-400 whitespace-nowrap ml-3">{w.perPersonPerDay}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="card card-accent">
          <h3 class="text-sm font-semibold text-brand-400 tracking-wide uppercase mb-4">Vorrat für 14 Tage</h3>
          <div class="space-y-3.5">
            {waterStorage.items.map((item) => (
              <div data-stagger>
                <div class="flex justify-between items-center text-sm">
                  <span class="text-surface-800">{item.group}</span>
                  <span class="font-semibold text-brand-400">{item.amount}</span>
                </div>
                <div class="text-2xs text-surface-600">{item.note}</div>
                <div class="mt-1.5 h-1 bg-surface-300 rounded-full overflow-hidden">
                  <div class="h-full bg-brand-600 rounded-full" style={`width: ${Math.min(100, (item.liters / 140) * 100)}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="card lg:col-span-3">
          <h3 class="text-sm font-semibold text-blue-400 tracking-wide uppercase mb-4">Wasseraufbereitung</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
            {waterPurification.map((m) => (
              <div class="p-4 rounded-xl bg-surface-200/50 hover:bg-surface-200 transition-colors" data-stagger>
                <h4 class="font-semibold text-sm text-surface-900 mb-1.5">{m.method}</h4>
                <p class="text-xs text-surface-600 mb-3 leading-relaxed">{m.description}</p>
                <div class="flex justify-between text-2xs text-surface-600">
                  <span>{m.effectiveness}</span>
                  <span>Aufwand: {m.effort}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Wasserrechner -->
      <div class="card card-accent p-6 mt-6" data-animate>
        <h3 class="text-sm font-bold text-surface-950 mb-2">Wasserrechner — Wie viel brauchst du?</h3>
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-4">
          <div>
            <label for="water-adults" class="text-xs font-semibold text-surface-700 block mb-1">Erwachsene</label>
            <input id="water-adults" type="number" min="0" value="2" class="w-full bg-surface-200 border border-surface-300 rounded-lg px-3 py-2 text-sm text-surface-900" />
          </div>
          <div>
            <label for="water-kids" class="text-xs font-semibold text-surface-700 block mb-1">Kinder</label>
            <input id="water-kids" type="number" min="0" value="3" class="w-full bg-surface-200 border border-surface-300 rounded-lg px-3 py-2 text-sm text-surface-900" />
          </div>
          <div>
            <label for="water-days" class="text-xs font-semibold text-surface-700 block mb-1">Tage</label>
            <input id="water-days" type="number" min="1" value="14" class="w-full bg-surface-200 border border-surface-300 rounded-lg px-3 py-2 text-sm text-surface-900" />
          </div>
          <div class="flex items-end">
            <button id="water-calc-btn" type="button" class="w-full px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white rounded-lg text-sm font-semibold transition-colors cursor-pointer">Berechnen</button>
          </div>
        </div>
        <div id="water-result" class="mt-4 p-4 bg-surface-200/50 rounded-lg text-sm text-surface-700 hidden" aria-live="polite" aria-atomic="true" role="status"></div>
      </div>
      </div>
      </details>
    </section>

    <!-- ===== NAHRUNG ===== -->
    <section class="py-3 sm:py-4 px-4 sm:px-6 max-w-7xl mx-auto">
      <details class="section-card group">
        <SectionHeader id="nahrung" title="Nahrung & Haltbarkeit" subtitle="Was wirklich lange hält und was du brauchst." accent="amber" collapsible />

      <div class="section-content">
      <div class="mb-4 sm:flex sm:justify-end" data-animate>
        <PdfButton pdfType="food" label="Nahrungsmittel PDF" sublabel={`${foodItems.length} Artikel (mehrseitig)`} accent="amber" />
      </div>

      <div class="sticky top-14 sm:top-16 z-30 bg-surface-0/95 backdrop-blur-md py-3 -mx-4 sm:-mx-6 px-4 sm:px-6 border-b border-surface-300/50">
        <div class="flex items-center gap-2 overflow-x-auto no-scrollbar pb-1" role="tablist" aria-label="Lebensmittel-Kategorien">
          <button class="food-tab tab is-active shrink-0" data-category="all" role="tab" aria-selected="true" aria-controls="food-table">Alle ({foodItems.length})</button>
          {foodCategories.map((cat) => (
            <button class="food-tab tab shrink-0" data-category={cat} role="tab" aria-selected="false" aria-controls="food-table">{cat} ({foodItems.filter(f => f.category === cat).length})</button>
          ))}
        </div>
      </div>

      <div id="food-table" role="tabpanel">
        <div class="overflow-x-auto rounded-xl border border-surface-300">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-surface-200 text-surface-600 text-xs uppercase tracking-wider">
                <th scope="col" class="text-left p-3 sm:p-4 font-medium">Lebensmittel</th>
                <th scope="col" class="text-left p-3 sm:p-4 font-medium">Haltbarkeit</th>
                <th scope="col" class="text-left p-3 sm:p-4 font-medium hidden sm:table-cell">Lagerung</th>
                <th scope="col" class="text-center p-3 sm:p-4 font-medium hidden md:table-cell">kcal/100g</th>
                <th scope="col" class="text-center p-3 sm:p-4 font-medium">Prio</th>
              </tr>
            </thead>
            <tbody>
              {foodItems.map((food, idx) => (
                <tr class={`food-row border-t border-surface-300/50 hover:bg-surface-200/30 transition-colors ${idx >= 20 ? 'food-hidden-row hidden' : ''}`} data-category={food.category}>
                  <td class="p-3 sm:p-4">
                    <div class="font-medium text-surface-900">{food.name}</div>
                    <div class="text-xs text-surface-600 mt-0.5 sm:hidden">{food.storage}</div>
                  </td>
                  <td class="p-3 sm:p-4 font-semibold text-amber-400 whitespace-nowrap">{food.shelf_life}</td>
                  <td class="p-3 sm:p-4 text-surface-600 text-xs hidden sm:table-cell">{food.storage}</td>
                  <td class="p-3 sm:p-4 text-center text-surface-700 hidden md:table-cell">{food.calories_per_100g}</td>
                  <td class="p-3 sm:p-4 text-center"><span class={badgeClass(food.priority)}>{food.priority}</span></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div id="food-show-all-wrap" class="text-center mt-4">
          <button id="food-show-all" type="button" class="px-6 py-2.5 bg-surface-200 hover:bg-surface-300 border border-surface-300 text-surface-800 rounded-lg text-sm font-semibold transition-colors cursor-pointer">
            Alle {foodItems.length} Lebensmittel anzeigen
          </button>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-8" data-animate>
        <BentoCard accent>
          <h4 class="font-semibold text-brand-400 text-sm mb-1">Unbegrenzt haltbar</h4>
          <p class="text-xs text-surface-600 leading-relaxed">Zucker, Honig, Salz und Essig halten ewig - solange sie trocken gelagert werden.</p>
        </BentoCard>
        <BentoCard>
          <h4 class="font-semibold text-amber-400 text-sm mb-1">Beste Langzeitnahrung</h4>
          <p class="text-xs text-surface-600 leading-relaxed">Reis hält bis zu 30 Jahre, Hülsenfrüchte 10 Jahre, NRG-5 sogar 20 Jahre. Die absoluten Gewinner.</p>
        </BentoCard>
        <BentoCard>
          <h4 class="font-semibold text-blue-400 text-sm mb-1">Konserven als Basis</h4>
          <p class="text-xs text-surface-600 leading-relaxed">Konserven halten 3-5 Jahre, brauchen keinen Strom und sind sofort essbar. Goldwert wenn nichts mehr geht.</p>
        </BentoCard>
      </div>

      <!-- Kalorienrechner -->
      <div class="card card-accent p-6 mt-6" data-animate>
        <h3 class="text-sm font-bold text-surface-950 mb-2">Kalorienrechner — Wie viel Nahrung für wie lange?</h3>
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-4">
          <div>
            <label for="cal-persons" class="text-xs font-semibold text-surface-700 block mb-1">Personen</label>
            <input id="cal-persons" type="number" min="1" value="5" class="w-full bg-surface-200 border border-surface-300 rounded-lg px-3 py-2 text-sm text-surface-900" />
          </div>
          <div>
            <label for="cal-daily" class="text-xs font-semibold text-surface-700 block mb-1">kcal/Person/Tag</label>
            <input id="cal-daily" type="number" min="500" value="2000" class="w-full bg-surface-200 border border-surface-300 rounded-lg px-3 py-2 text-sm text-surface-900" />
          </div>
          <div>
            <label for="cal-days" class="text-xs font-semibold text-surface-700 block mb-1">Tage</label>
            <input id="cal-days" type="number" min="1" value="14" class="w-full bg-surface-200 border border-surface-300 rounded-lg px-3 py-2 text-sm text-surface-900" />
          </div>
          <div class="flex items-end">
            <button id="cal-calc-btn" type="button" class="w-full px-4 py-2 bg-amber-600 hover:bg-amber-500 text-white rounded-lg text-sm font-semibold transition-colors cursor-pointer">Berechnen</button>
          </div>
        </div>
        <div id="cal-result" class="mt-4 p-4 bg-surface-200/50 rounded-lg text-sm text-surface-700 hidden" aria-live="polite" aria-atomic="true" role="status"></div>
      </div>
      </div>
      </details>
    </section>

    <!-- ===== EINKAUFSLISTEN ===== -->
    <section class="py-3 sm:py-4 px-4 sm:px-6 max-w-7xl mx-auto">
      <details class="section-card group">
        <SectionHeader id="einkaufslisten" title="Einkaufslisten" subtitle="Fertige Listen für jede Haushaltsgröße." accent="brand" collapsible />

      <div class="section-content">
      <div class="flex flex-wrap gap-2 mb-8" data-animate role="tablist" aria-label="Einkaufslisten">
        {shoppingLists.map((list, i) => (
          <button class={`shop-tab tab ${i === 0 ? 'is-active' : ''}`} data-idx={String(i)} role="tab" aria-selected={i === 0 ? 'true' : 'false'} aria-controls={`shop-panel-${i}`}>
            {list.title}
          </button>
        ))}
      </div>

      {shoppingLists.map((list, listIndex) => {
        const categories = [...new Set(list.items.map(i => i.category))];
        return (
          <div class={`shop-panel ${listIndex === 0 ? '' : 'hidden'}`} data-idx={String(listIndex)} id={`shop-panel-${listIndex}`} role="tabpanel">
            <div data-animate>
              <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6">
                <div>
                  <h3 class="text-xl font-bold text-surface-950">{list.title}</h3>
                  <p class="text-sm text-surface-600">{list.description} -- {list.items.length} Artikel</p>
                </div>
                <PdfButton pdfType={`shop-${listIndex}`} label="Als PDF herunterladen" sublabel={`${list.items.length} Artikel`} accent="brand" />
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {categories.map((cat) => (
                  <BentoCard accent={cat === 'Wasser' || cat === 'Notnahrung'}>
                    <h4 class="text-xs font-semibold text-surface-600 uppercase tracking-wider mb-3 flex items-center gap-2">
                      <span class="w-1.5 h-1.5 rounded-full bg-brand-500"></span>
                      {cat}
                    </h4>
                    <ul class="space-y-1.5">
                      {list.items.filter(i => i.category === cat).map((item) => (
                        <li class="flex justify-between items-start gap-2 text-sm" data-stagger>
                          <span class="text-surface-800">{item.name}</span>
                          <span class="text-brand-400 font-medium whitespace-nowrap text-xs">{item.amount}</span>
                        </li>
                      ))}
                    </ul>
                  </BentoCard>
                ))}
              </div>
            </div>
          </div>
        );
      })}
      </div>
      </details>
    </section>

    <!-- ===== ERSTE HILFE ===== -->
    <section class="py-3 sm:py-4 px-4 sm:px-6 max-w-7xl mx-auto">
      <details class="section-card group">
        <SectionHeader id="erste-hilfe" title="Erste Hilfe" subtitle="Zusammengestellt nach DRK-Empfehlungen." accent="rose" collapsible />

      <div class="section-content">
      <div data-animate>
        <div class="mb-4 sm:flex sm:justify-end">
          <PdfButton pdfType="firstaid" label="Erste-Hilfe PDF" sublabel={`${firstAidKit.items.length} Artikel`} accent="rose" />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
          {firstAidKit.items.map((item) => (
            <div class="flex items-center justify-between p-3.5 rounded-xl bg-surface-100 border border-surface-300/50 hover:border-surface-400 transition-colors" data-stagger>
              <div class="flex items-center gap-2.5 min-w-0">
                <span class={`flex-shrink-0 w-1.5 h-1.5 rounded-full ${item.priority === 'hoch' ? 'bg-rose-500' : item.priority === 'mittel' ? 'bg-amber-500' : 'bg-blue-500'}`}></span>
                <span class="text-sm text-surface-800 truncate">{item.item}</span>
              </div>
              <div class="flex items-center gap-2 flex-shrink-0 ml-2">
                <span class="text-xs text-surface-600">{item.amount}</span>
                <span class={badgeClass(item.priority)}>{item.priority}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
      </div>
      </details>
    </section>

    <!-- ===== AUSRÜSTUNG ===== -->
    <section class="py-3 sm:py-4 px-4 sm:px-6 max-w-7xl mx-auto">
      <details class="section-card group">
        <SectionHeader id="ausruestung" title="Ausrüstung & Werkzeuge" subtitle="Das brauchst du, um ohne Strom klarzukommen." accent="orange" collapsible />

      <div class="section-content">
      <div class="mb-4 sm:flex sm:justify-end" data-animate>
        <PdfButton pdfType="equipment" label="Ausrüstung PDF" sublabel="Komplette Liste" accent="amber" />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" data-animate>
        {toolsAndEquipment.map((group) => (
          <BentoCard span={group.category === 'Schutz & Wärme' ? 'lg:col-span-2' : ''}>
            <h3 class="text-sm font-semibold text-surface-950 uppercase tracking-wide mb-4">{group.category}</h3>
            <div class="space-y-1.5">
              {group.items.map((item) => (
                <div class="flex items-start justify-between p-2.5 rounded-lg bg-surface-200/40 hover:bg-surface-200 transition-colors text-sm" data-stagger>
                  <div class="min-w-0">
                    <span class="font-medium text-surface-800">{item.name}</span>
                    <span class="text-xs text-surface-600 block">{item.note}</span>
                  </div>
                  <span class="text-xs font-medium text-amber-400 whitespace-nowrap ml-3 mt-0.5">{item.amount}</span>
                </div>
              ))}
            </div>
          </BentoCard>
        ))}
      </div>
      </div>
      </details>
    </section>

    <!-- ===== HYGIENE ===== -->
    <section class="py-3 sm:py-4 px-4 sm:px-6 max-w-7xl mx-auto">
      <details class="section-card group">
        <SectionHeader id="hygiene" title="Hygiene" subtitle="Ohne Hygiene breiten sich Krankheiten schneller aus als alles andere." accent="cyan" collapsible />

      <div class="section-content">
      <div data-animate>
        <div class="mb-4 sm:flex sm:justify-end">
          <PdfButton pdfType="hygiene" label="Hygiene PDF" sublabel={`${hygieneItems.length} Artikel`} accent="cyan" />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
          {hygieneItems.map((item) => (
            <div class="flex items-center justify-between p-3.5 rounded-xl bg-surface-100 border border-surface-300/50 hover:border-surface-400 transition-colors" data-stagger>
              <div class="flex items-center gap-2.5">
